---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { id?: string };

const { title, description, pubDate, updatedDate, heroImage, series, seriesOrder, id } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const seriesPosts = series
	? (await getCollection('blog'))
			.filter((p) => p.data.series === series)
			.sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))
	: [];
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose">
					<header class="post-header">
						<div class="meta">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="updated">· 수정됨 <FormattedDate date={updatedDate} /></span>
							)}
						</div>
						<h1>{title}</h1>
						{description && <p class="description">{description}</p>}
					</header>
					<hr />
					<slot />
				</div>

				{seriesPosts.length > 0 && (
					<div class="series-panel">
						<div class="series-header">
							<span class="series-label">시리즈</span>
							<a href={`${base}/series/${series}`} class="series-name">{series}</a>
						</div>
						<ol class="series-list">
							{seriesPosts.map((p) => (
								<li class:list={[{ current: p.id === id }]}>
									{p.id === id ? (
										<span class="series-item-current">{p.data.title}</span>
									) : (
										<a href={`${base}/posts/${p.id}/`}>{p.data.title}</a>
									)}
								</li>
							))}
						</ol>
					</div>
				)}

				<div class="comments">
					<Comments client:load />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 680px;
		margin: 0 auto;
		padding: 2rem 1.5rem 4rem;
	}

	.hero-image {
		width: 100%;
		max-width: 680px;
		margin: 0 auto 0;
	}

	.hero-image img {
		display: block;
		width: 100%;
		border-radius: 12px;
	}

	.prose {
		width: 100%;
	}

	.post-header {
		padding: 2rem 0 1rem;
	}

	.meta {
		font-size: 0.85rem;
		color: var(--color-text-muted);
		margin-bottom: 0.75rem;
	}

	.updated {
		margin-left: 0.25rem;
	}

	h1 {
		font-size: clamp(1.6rem, 4vw, 2.2rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.2;
		margin: 0 0 0.75rem;
		color: var(--color-text);
	}

	.description {
		font-size: 1.05rem;
		color: var(--color-text-muted);
		line-height: 1.6;
		margin: 0;
	}

	hr {
		border: none;
		border-top: 1px solid var(--color-border);
		margin: 1.5rem 0 2rem;
	}

	.series-panel {
		margin-top: 3rem;
		padding: 1.25rem 1.5rem;
		background-color: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 10px;
	}

	.series-header {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}

	.series-label {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--color-text-muted);
	}

	.series-name {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--color-primary);
		text-decoration: none;
	}

	.series-name:hover {
		text-decoration: underline;
	}

	.series-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		counter-reset: series-counter;
	}

	.series-list li {
		counter-increment: series-counter;
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		font-size: 0.9rem;
	}

	.series-list li::before {
		content: counter(series-counter);
		font-size: 0.75rem;
		color: var(--color-text-muted);
		min-width: 1rem;
		text-align: right;
		flex-shrink: 0;
	}

	.series-list li a {
		color: var(--color-text);
		text-decoration: none;
	}

	.series-list li a:hover {
		color: var(--color-primary);
	}

	.series-list li.current .series-item-current {
		color: var(--color-primary);
		font-weight: 600;
	}

	.comments {
		margin-top: 4rem;
		padding-top: 2rem;
		border-top: 1px solid var(--color-border);
	}
</style>
