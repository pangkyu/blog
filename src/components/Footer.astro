---
import { GITHUB_URL, SITE_AUTHOR } from '../consts';

const today = new Date();
---

<footer>
	<div class="inner">
		<span class="copy">&copy; {today.getFullYear()} {SITE_AUTHOR}</span>
		
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--color-border);
		margin-top: 4rem;
	}

	.inner {
		max-width: 680px;
		margin: 0 auto;
		padding: 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.copy {
		font-size: 0.85rem;
		color: var(--color-text-muted);
	}

	a {
		color: var(--color-text-muted);
		text-decoration: none;
		display: flex;
		align-items: center;
		transition: color 0.15s;
	}

	a:hover {
		color: var(--color-text);
	}
</style>
